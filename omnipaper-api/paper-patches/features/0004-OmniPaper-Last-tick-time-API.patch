From 443ae96d9cf7da567ca77c1ab24bbd514b3067e8 Mon Sep 17 00:00:00 2001
From: OmniPaper <omnipaper@omnipaper.io>
Date: Thu, 11 Jun 2026 08:37:03 +0000
Subject: [PATCH] OmniPaper - Last tick time API

License: MIT (https://opensource.org/licenses/MIT)
Gale - https://galemc.org
---
 src/main/java/org/bukkit/Bukkit.java | 14 ++++++++++++++
 src/main/java/org/bukkit/Server.java | 17 +++++++++++++++++
 2 files changed, 31 insertions(+)

diff --git a/src/main/java/org/bukkit/Bukkit.java b/src/main/java/org/bukkit/Bukkit.java
index 6651ce7..d958545 100644
--- a/src/main/java/org/bukkit/Bukkit.java
+++ b/src/main/java/org/bukkit/Bukkit.java
@@ -3036,6 +3036,20 @@ public final class Bukkit {
     }
     // Paper end - Folia region threading API
 
+    // Gale start - YAPFA - last tick time - API
+    public static long getLastTickTotalTime() {
+        return server.getLastTickTotalTime();
+    }
+
+    public static long getLastTickProperTime() {
+        return server.getLastTickProperTime();
+    }
+
+    public static long getLastTickOversleepTime() {
+        return server.getLastTickOversleepTime();
+    }
+    // Gale end - YAPFA - last tick time - API
+
     /**
      * @deprecated All methods on this class have been deprecated, see the individual methods for replacements.
      */
diff --git a/src/main/java/org/bukkit/Server.java b/src/main/java/org/bukkit/Server.java
index b838dfe..4e82d93 100644
--- a/src/main/java/org/bukkit/Server.java
+++ b/src/main/java/org/bukkit/Server.java
@@ -2785,6 +2785,23 @@ public interface Server extends PluginMessageRecipient, net.kyori.adventure.audi
     public boolean isGlobalTickThread();
     // Paper end - Folia region threading API
 
+    // Gale start - YAPFA - last tick time - API
+    /**
+     * Gets the total time spent in the last tick in milliseconds.
+     */
+    long getLastTickTotalTime();
+
+    /**
+     * Gets the processing time in the last tick in milliseconds (excluding oversleep).
+     */
+    long getLastTickProperTime();
+
+    /**
+     * Gets the oversleep time in the last tick in milliseconds.
+     */
+    long getLastTickOversleepTime();
+    // Gale end - YAPFA - last tick time - API
+
     // Paper start - API to check if the server is sleeping
     /**
      * Returns whether the server is sleeping/paused.
