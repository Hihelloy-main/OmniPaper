+++ b/ca/spottedleaf/moonrise/patches/chunk_system/level/entity/ChunkEntitySlices.java
@@ -538,11 +538,18 @@ public final class ChunkEntitySlices {
                 }
 
                 final Entity[] storage = list.storage;
+                final int len = Math.min(storage.length, list.size());
+                // OmniPaper start - inline AABB intersects
+                final double boxMinX = box.minX, boxMinY = box.minY, boxMinZ = box.minZ;
+                final double boxMaxX = box.maxX, boxMaxY = box.maxY, boxMaxZ = box.maxZ;
 
-                for (int i = 0, len = Math.min(storage.length, list.size()); i < len; ++i) {
+                for (int i = 0; i < len; ++i) {
                     final Entity entity = storage[i];
 
-                    if (entity == null || entity == except || !entity.getBoundingBox().intersects(box)) {
+                    if (entity == null || entity == except) continue;
+                    final AABB entityBB = entity.getBoundingBox();
+                    if (entityBB.maxX <= boxMinX || entityBB.minX >= boxMaxX || entityBB.maxY <= boxMinY || entityBB.minY >= boxMaxY || entityBB.maxZ <= boxMinZ || entityBB.minZ >= boxMaxZ) {
+                        // OmniPaper end - inline AABB intersects
                         continue;
                     }
 
