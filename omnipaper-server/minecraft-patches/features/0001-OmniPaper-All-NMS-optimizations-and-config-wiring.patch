@@ -50,6 +50,43 @@ public abstract class Projectile extends Entity implements TraceableEntity {
         super(type, level);
     }
 
+    // OmniPaper start - reduce projectile chunk loading
+    private static int omniChunksLoadedThisTick = 0;
+    private static int omniChunksLoadedInTick = 0;
+    private int omniChunksLoadedByThis = 0;
+    private static final int OMNI_MAX_CHUNKS_PER_TICK = 10;
+    private static final int OMNI_MAX_CHUNKS_PER_PROJECTILE = 8;
+
+    @Override
+    public void setPos(double x, double y, double z) {
+        int currentTick = net.minecraft.server.MinecraftServer.currentTick;
+        if (omniChunksLoadedInTick != currentTick) {
+            omniChunksLoadedInTick = currentTick;
+            omniChunksLoadedThisTick = 0;
+        }
+        int prevChunkX = Mth.floor(this.getX()) >> 4;
+        int prevChunkZ = Mth.floor(this.getZ()) >> 4;
+        int newChunkX = Mth.floor(x) >> 4;
+        int newChunkZ = Mth.floor(z) >> 4;
+        if (prevChunkX != newChunkX || prevChunkZ != newChunkZ) {
+            boolean loaded = ((net.minecraft.server.level.ServerChunkCache) this.level().getChunkSource())
+                    .getChunkAtIfLoadedImmediately(newChunkX, newChunkZ) != null;
+            if (!loaded) {
+                if (omniChunksLoadedThisTick >= OMNI_MAX_CHUNKS_PER_TICK) {
+                    return;
+                }
+                if (this.omniChunksLoadedByThis >= OMNI_MAX_CHUNKS_PER_PROJECTILE) {
+                    this.discard();
+                    return;
+                }
+                omniChunksLoadedThisTick++;
+                this.omniChunksLoadedByThis++;
+            }
+        }
+        super.setPos(x, y, z);
+    }
+    // OmniPaper end - reduce projectile chunk loading
+
     protected void setOwner(@Nullable EntityReference<Entity> owner) {
         this.owner = owner;
         this.refreshProjectileSource(false); // Paper
