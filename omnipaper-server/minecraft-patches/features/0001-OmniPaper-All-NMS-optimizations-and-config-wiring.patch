+    // OmniPaper start - useless packet helper
+    private boolean isOmniUselessPacket(@Nullable Packet<?> packet) {
+        if (!(packet instanceof ClientboundMoveEntityPacket p)) return false;
+        return switch (packet) {
+            case ClientboundMoveEntityPacket.Pos ignored -> p.getXa() == 0 && p.getYa() == 0 && p.getZa() == 0;
+            case ClientboundMoveEntityPacket.PosRot ignored -> p.getXa() == 0 && p.getYa() == 0 && p.getZa() == 0 && p.getYRot() == 0 && p.getXRot() == 0;
+            case ClientboundMoveEntityPacket.Rot ignored -> p.getYRot() == 0 && p.getXRot() == 0;
+            default -> false;
+        };
+    }
+    // OmniPaper end - useless packet helper
