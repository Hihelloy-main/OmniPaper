Date: Thu, 11 Jun 2026 00:00:00 +0000
Subject: [PATCH] OmniPaper - Reduce projectile chunk loading

Based on Airplane/Gale patch by Paul Sauve and Martijn Muijsers.
Limits how many unloaded chunks a projectile can force-load per tick
and per projectile lifetime. Critical for ability spam at 400 players.

diff --git a/net/minecraft/world/entity/projectile/Projectile.java b/net/minecraft/world/entity/projectile/Projectile.java
--- a/net/minecraft/world/entity/projectile/Projectile.java
+++ b/net/minecraft/world/entity/projectile/Projectile.java
@@ -50,6 +50,44 @@ public abstract class Projectile extends Entity implements TraceableEntity {
         super(type, level);
     }
 
+    // OmniPaper start - reduce projectile chunk loading
+    private static int chunksLoadedThisTick = 0;
+    private static int chunksLoadedInTick;
+    private int chunksLoadedByProjectile = 0;
+    private static final int MAX_CHUNKS_PER_TICK = 10;
+    private static final int MAX_CHUNKS_PER_PROJECTILE = 8;
+
+    @Override
+    public void setPos(double x, double y, double z) {
+        int currentTick = net.minecraft.server.MinecraftServer.currentTick;
+
+        if (chunksLoadedInTick != currentTick) {
+            chunksLoadedInTick = currentTick;
+            chunksLoadedThisTick = 0;
+        }
+
+        int previousX = Mth.floor(this.getX()) >> 4;
+        int previousZ = Mth.floor(this.getZ()) >> 4;
+        int newX = Mth.floor(x) >> 4;
+        int newZ = Mth.floor(z) >> 4;
+
+        if (previousX != newX || previousZ != newZ) {
+            boolean isLoaded = ((net.minecraft.server.level.ServerChunkCache) this.level().getChunkSource())
+                .getChunkAtIfLoadedImmediately(newX, newZ) != null;
+
+            if (!isLoaded) {
+                if (chunksLoadedThisTick >= MAX_CHUNKS_PER_TICK) {
+                    return;
+                }
+                if (this.chunksLoadedByProjectile >= MAX_CHUNKS_PER_PROJECTILE) {
+                    this.discard();
+                    return;
+                }
+                chunksLoadedThisTick++;
+                this.chunksLoadedByProjectile++;
+            }
+        }
+
+        super.setPos(x, y, z);
+    }
+    // OmniPaper end - reduce projectile chunk loading
+
     protected void setOwner(@Nullable EntityReference<Entity> owner) {
         this.owner = owner;
         this.refreshProjectileSource(false); // Paper
