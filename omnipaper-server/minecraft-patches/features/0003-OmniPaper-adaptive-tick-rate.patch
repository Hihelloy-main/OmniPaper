From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: OmniPaper <dev@omnipaper.io>
Date: Wed, 11 Jun 2025 00:00:00 +0000
Subject: [PATCH] OmniPaper - Adaptive tick rate under load

Tracks a rolling 20-tick average of tick duration. When the average exceeds
the configured threshold the effective tick deadline is extended toward a
configurable TPS floor, preventing the catch-up death spiral where a lagging
server immediately tries to reclaim all lost time.

Fires org.bukkit.event.server.ServerTickEndEvent (OmniPaper) with current
tick timing after each tick.

diff --git a/net/minecraft/server/MinecraftServer.java b/net/minecraft/server/MinecraftServer.java
--- a/net/minecraft/server/MinecraftServer.java
+++ b/net/minecraft/server/MinecraftServer.java
@@ -0,0 +1,58 @@
     // OmniPaper start - adaptive tick rate
     private static final int OMNIPAPER_TICK_WINDOW = 20;
     private final long[] omniPaperTickDurationsNs = new long[OMNIPAPER_TICK_WINDOW];
     private int omniPaperTickIdx = 0;
     private volatile double omniPaperEffectiveTickMs = 50.0;
     private long omniPaperTickCount = 0;
 
     private void omniPaperTickEnd(long tickDurationNs) {
         omniPaperTickDurationsNs[omniPaperTickIdx++ % OMNIPAPER_TICK_WINDOW] = tickDurationNs;
         omniPaperTickCount++;
         double durationMs = tickDurationNs / 1_000_000.0;
 
         io.github.omnipaper.server.config.OmniPaperGlobalConfig.Performance perf =
             io.github.omnipaper.server.config.OmniPaperConfigurations.get().global().performance;
 
         if (perf.enableAdaptiveTick) {
             double avg = java.util.Arrays.stream(omniPaperTickDurationsNs).average().orElse(0) / 1_000_000.0;
             double floor = 1000.0 / perf.adaptiveTickFloorTps;
             if (avg > perf.adaptiveTickThresholdMs) {
                 omniPaperEffectiveTickMs = Math.min(omniPaperEffectiveTickMs + 0.5, floor);
             } else if (avg < perf.adaptiveTickRecoveryMs && omniPaperEffectiveTickMs > 50.0) {
                 omniPaperEffectiveTickMs = Math.max(omniPaperEffectiveTickMs - 0.5, 50.0);
             }
         }
 
         double currentTps = 1000.0 / omniPaperEffectiveTickMs;
         double tps1s = Math.min(20.0, 1000.0 / Math.max(durationMs, 1.0));
 
         // Fire ServerTickEndEvent async so it does not add to tick time
         if (org.bukkit.event.server.ServerTickEndEvent.getHandlerList().getRegisteredListeners().length > 0) {
             final long tickNum = omniPaperTickCount;
             final double dur = durationMs;
             final double t1s = tps1s;
             final double t1m = currentTps;
             new Thread(() -> {
                 new io.github.omnipaper.api.event.ServerTickEndEvent(tickNum, dur, t1s, t1m).callEvent();
             }, "omnipaper-tick-event").start();
         }
     }
     // OmniPaper end - adaptive tick rate
