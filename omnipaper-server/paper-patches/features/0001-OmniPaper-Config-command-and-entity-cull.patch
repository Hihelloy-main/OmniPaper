From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Hihelloy <Hihelloylovesu@gmail.com>
Date: Thu, 11 Jun 2026 00:00:00 +0000
Subject: [PATCH] OmniPaper - Config command and entity cull

Load OmniPaper config in enablePlugins(POSTWORLD).
Register /omnipaper command.
Start daemon thread for entity culling.
Hook config reload into server reload.

diff --git a/src/main/java/org/bukkit/craftbukkit/CraftServer.java b/src/main/java/org/bukkit/craftbukkit/CraftServer.java
index da49c8005592a154946750591ce082796f24dd3b..e635b0c4e7c8b3b8a4698ae043d28fa7ed637a45 100644
--- a/src/main/java/org/bukkit/craftbukkit/CraftServer.java
+++ b/src/main/java/org/bukkit/craftbukkit/CraftServer.java
@@ -605,6 +605,44 @@ public final class CraftServer implements Server {
             CraftDefaultPermissions.registerCorePermissions();
             if (!io.papermc.paper.configuration.GlobalConfiguration.get().misc.loadPermissionsYmlBeforePlugins) this.loadCustomPermissions(); // Paper
             this.syncCommands();
+            // OmniPaper start - config, command and entity cull
+            if (io.github.omnipaper.server.config.OmniPaperConfigurations.get() == null) {
+                try {
+                    io.github.omnipaper.server.config.OmniPaperConfigurations.setup();
+                } catch (Exception e) {
+                    this.getLogger().severe("Failed to load OmniPaper config: " + e.getMessage());
+                }
+            }
+            this.commandMap.register("omnipaper", "omnipaper", new io.github.omnipaper.server.command.OmniPaperCommand());
+            io.github.omnipaper.server.config.OmniPaperGlobalConfig.Performance perf =
+                io.github.omnipaper.server.config.OmniPaperConfigurations.get().global().performance;
+            if (perf.entityCullEnabled) {
+                long intervalMs = perf.entityCullIntervalTicks * 50L;
+                Thread cullThread = new Thread(() -> {
+                    while (this.getServer().isRunning()) {
+                        try {
+                            Thread.sleep(intervalMs);
+                        } catch (InterruptedException ex) {
+                            Thread.currentThread().interrupt();
+                            break;
+                        }
+                        for (org.bukkit.World world : this.getWorlds()) {
+                            for (org.bukkit.entity.Entity entity : world.getEntities()) {
+                                if (entity instanceof org.bukkit.entity.LivingEntity living
+                                    && !living.hasAI()
+                                    && !living.isCustomNameVisible()
+                                    && living.getType() != org.bukkit.entity.EntityType.PLAYER
+                                    && living.getType() != org.bukkit.entity.EntityType.ARMOR_STAND) {
+                                    living.remove();
+                                }
+                            }
+                        }
+                    }
+                }, "omnipaper-entity-cull");
+                cullThread.setDaemon(true);
+                cullThread.start();
+            }
+            // OmniPaper end - config, command and entity cull
         }
     }
 
@@ -1024,6 +1062,15 @@ public final class CraftServer implements Server {
         org.spigotmc.SpigotConfig.registerCommands(); // Spigot
         io.papermc.paper.command.PaperCommands.registerCommands(this.console); // Paper
         this.spark.registerCommandBeforePlugins(this); // Paper - spark
+        // OmniPaper start - reload config
+        try {
+            if (io.github.omnipaper.server.config.OmniPaperConfigurations.get() != null) {
+                io.github.omnipaper.server.config.OmniPaperConfigurations.get().reload();
+            }
+        } catch (Exception e) {
+            this.getLogger().severe("Failed to reload OmniPaper config: " + e.getMessage());
+        }
+        // OmniPaper end - reload config
         this.overrideAllCommandBlockCommands = this.commandsConfiguration.getStringList("command-block-overrides").contains("*");
         this.ignoreVanillaPermissions = this.commandsConfiguration.getBoolean("ignore-vanilla-permissions");
 
