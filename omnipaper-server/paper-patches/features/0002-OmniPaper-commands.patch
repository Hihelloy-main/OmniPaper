From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: OmniPaper <dev@omnipaper.io>
Date: Wed, 11 Jun 2025 00:00:00 +0000
Subject: [PATCH] OmniPaper - Commands

Registers the /omnipaper command and its permission node.

diff --git a/src/main/java/org/bukkit/craftbukkit/util/permissions/CraftDefaultPermissions.java b/src/main/java/org/bukkit/craftbukkit/util/permissions/CraftDefaultPermissions.java
index 0000000000000000000000000000000000000003..0000000000000000000000000000000000000004 100644
--- a/src/main/java/org/bukkit/craftbukkit/util/permissions/CraftDefaultPermissions.java
+++ b/src/main/java/org/bukkit/craftbukkit/util/permissions/CraftDefaultPermissions.java
@@ -6,10 +6,17 @@ import org.bukkit.util.permissions.DefaultPermissions;
 public final class CraftDefaultPermissions {
     private static final String ROOT = "minecraft";
 
+    // OmniPaper start - commands
+    public static final String OMNIPAPER_ROOT = "omnipaper";
+    // OmniPaper end - commands
+
     private CraftDefaultPermissions() {}
 
     public static void registerCorePermissions() {
         org.bukkit.permissions.Permission parent = DefaultPermissions.registerPermission(ROOT, "Gives the user the ability to use all Vanilla utilities and commands");
+        // OmniPaper start - commands
+        org.bukkit.permissions.Permission omniParent = DefaultPermissions.registerPermission(OMNIPAPER_ROOT, "OmniPaper root permission");
+        DefaultPermissions.registerPermission(OMNIPAPER_ROOT + ".command", "Allows use of the /omnipaper command", org.bukkit.permissions.PermissionDefault.OP, omniParent);
+        // OmniPaper end - commands
         // Paper start - Add permissions for other commands

diff --git a/src/main/java/org/bukkit/craftbukkit/CraftServer.java b/src/main/java/org/bukkit/craftbukkit/CraftServer.java
index 0000000000000000000000000000000000000005..0000000000000000000000000000000000000006 100644
--- a/src/main/java/org/bukkit/craftbukkit/CraftServer.java
+++ b/src/main/java/org/bukkit/craftbukkit/CraftServer.java
@@ -0,0 +1,5 @@
+        // OmniPaper start - register command
+        this.commandMap.register("omnipaper", "omnipaper", new io.github.omnipaper.server.command.OmniPaperCommand());
+        // OmniPaper end - register command
