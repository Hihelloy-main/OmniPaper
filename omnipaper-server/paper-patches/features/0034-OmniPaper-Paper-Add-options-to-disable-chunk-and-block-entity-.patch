From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Nassim Jahnke <nassim@njahnke.dev>
Date: Sun, 26 Apr 2026 17:09:05 +0200
Subject: [PATCH] OmniPaper - Paper: Add options to disable chunk and block entity ticking

Original license: GPL-3.0-only
Original project: https://github.com/PaperMC/Paper
Paper commit: https://github.com/PaperMC/Paper/commit/acfe105b9dd64f4b3179ce2575e3809568974a20

Backported from Paper 26.1.2

diff --git a/src/main/java/io/papermc/paper/configuration/WorldConfiguration.java b/src/main/java/io/papermc/paper/configuration/WorldConfiguration.java
--- a/src/main/java/io/papermc/paper/configuration/WorldConfiguration.java
+++ b/src/main/java/io/papermc/paper/configuration/WorldConfiguration.java
@@ -488,6 +488,14 @@ public class WorldConfiguration extends ConfigurationPart {
     public class UnsupportedSettings extends ConfigurationPart {
         public boolean fixInvulnerableEndCrystalExploit = true;
         public boolean disableWorldTickingWhenEmpty = false;
+        // Paper start - Add options to disable chunk and block entity ticking
+        public Ticking ticking;
+
+        public class Ticking extends ConfigurationPart {
+            public boolean chunks = true;
+            public boolean blockEntities = true;
+        }
+        // Paper end - Add options to disable chunk and block entity ticking
     }
 
     public Hopper hopper;
